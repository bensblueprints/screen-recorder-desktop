{
  "name": "bloomrecorder",
  "productName": "BloomRecorder",
  "version": "1.1.0",
  "description": "BloomRecorder — local-first screen & camera recorder. Record your screen, webcam, or both (split or picture-in-picture) with mic + system audio, save locally, export MP4/GIF. Pay once, own it forever — no subscription, no cloud, no watermark.",
  "author": "Ben (bensblueprints)",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/smoke.js",
    "dist": "node scripts/build-win.js",
    "dist:win": "node scripts/build-win.js",
    "dist:mac": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "ffmpeg-static": "^5.2.0"
  },
  "build": {
    "appId": "com.bloomrecorder.app",
    "productName": "BloomRecorder",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    }
  }
}
